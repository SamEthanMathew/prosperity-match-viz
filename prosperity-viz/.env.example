# Copy to .env.local for local dev. Set the same keys in Vercel (Production + Preview).

# Supabase: Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Backtest API: leave empty to use Vite dev proxy → http://127.0.0.1:8787 (run backtest-api locally).
# Or set to your self-hosted API origin, e.g. https://backtest.example.com
VITE_BACKTEST_API_URL=
