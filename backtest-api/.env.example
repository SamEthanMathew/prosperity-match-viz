# Absolute path to the rust_backtester binary (cargo build --release path)
RUST_BACKTESTER_BIN=/path/to/prosperity_rust_backtester/target/release/rust_backtester

# Parent folder that contains tutorial/, round1/, … (same layout as prosperity_rust_backtester/datasets)
BACKTEST_DATASETS_ROOT=/path/to/prosperity_rust_backtester/datasets

# Monte Carlo backtester command (prosperity4mcbt CLI).
# Install from the imc-prosperity-4 repo: cd backtester && pip install -e .
# Defaults to "prosperity4mcbt" (assumes it is on PATH).
# Use an absolute path or just the command name if it is in your venv's bin/.
# MC_BIN=prosperity4mcbt

# API port (Vite proxies /api here in dev)
PORT=8787

# Recommended on macOS: PyO3 needs libpython; API resolves symlinks (e.g. /usr/local/bin/python3.13 → Frameworks)
# PYTHON_BIN=/usr/local/bin/python3.13

# Set to * to allow any Origin (use when UI is on another host than the API)
# BACKTEST_CORS_ORIGIN=*
